# AWS Configuration
aws_region = "us-east-1"

# Project Configuration
project_name = "smile-game-frontend"
environment  = "prod"

# S3 Bucket Configuration
# IMPORTANT: Bucket name must be globally unique
bucket_name = "smile-game-frontend-prod-750761633674"

# CloudFront Configuration
enable_ipv6 = true
price_class = "PriceClass_100" # Options: PriceClass_All, PriceClass_200, PriceClass_100

# Custom Domain Configuration
custom_domain        = "learnfi.online"
acm_certificate_arn  = "arn:aws:acm:us-east-1:750761633674:certificate/f4f52445-68bf-4c06-9c7d-acddb0f46801"

# S3 Versioning
enable_versioning = true

# Deployment Bucket (Optional)
create_deployment_bucket = false

